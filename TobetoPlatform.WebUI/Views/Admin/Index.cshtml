@model List<TobetoPlatform.Entities.Course>

@{
    ViewData["Title"] = "Admin - Kurs Yönetimi";
}

<h1>Kurs Yönetimi</h1>

<p>
    <a class="btn btn-primary" asp-action="AddCourse">Yeni Kurs Ekle</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Kurs Adı</th>
            <th>Fiyat</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Price.ToString("C")</td>
                <td>
                    <a class="btn btn-sm btn-warning" asp-action="EditCourse" asp-route-id="@item.Id">Düzenle</a> |
                    <form asp-action="DeleteCourse" method="post" onsubmit="return confirm('Bu kursu kaldırmak istediğinizden emin misiniz?');" style="display:inline;">
                        <input type="hidden" name="id" value="@item.Id" />
                        <button type="submit" class="btn btn-sm btn-danger">Kaldır</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>