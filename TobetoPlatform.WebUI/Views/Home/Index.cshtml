@model List<TobetoPlatform.Entities.Course>

@{
    ViewData["Title"] = "Tüm Kurslar";
}

<div class="text-center">
    <h1 class="display-4">Platform Kursları</h1>
</div>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Kurs Adı</th>
            <th>Açıklama</th>
            <th>Fiyat</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var course in Model)
        {
            <tr>
                <td>@course.Name</td>
                <td>@course.Description</td>
                <td>@course.Price.ToString("C")</td>
            </tr>
        }
    </tbody>
</table>